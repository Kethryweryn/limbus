generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id             String     @id @default(cuid())
  title          String
  description    String
  noteIntention  String?
  teaserUrl      String?
  slug           String     @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  published      Boolean    @default(true)
  publicPage     Boolean    @default(false)

  characters     Character[]
  factions       Faction[]
  intrigues      Intrigue[]
  items          Item[]
  timelineEvents TimelineEvent[]
  sessions       Session[]
  documents      Document[]
  locations      Location[]
  participantLinks ParticipantGame[]
}

model Character {
  id                    String     @id @default(cuid())
  name                  String
  type                  String     @default("pj")
  pitch                 String?
  background            String?
  backgroundDocumentUrl String?
  sheetReadyToSend      Boolean    @default(false)
  costumeIndications    String?
  excludeFromTrombinoscope Boolean @default(false)
  trombinoscopeFaceHidden  Boolean @default(false)
  trombinoscopePhotoUrl    String?
  trombinoscopeNote        String?
  trombinoscopeDisplayName String?
  slug                  String     @unique
  gameId                String
  game                  Game       @relation(fields: [gameId], references: [id])
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  published             Boolean    @default(true)

  factions              Faction[]  @relation("CharacterFactions")
  intrigues             Intrigue[] @relation("CharacterIntrigues")
  documents             Document[]
  targetedDocuments     Document[] @relation("DocumentCharacters")
  sessionAssignments    SessionAssignment[]
  items                 Item[]      @relation("CharacterItems")
  locatedItems          Item[]      @relation("ItemLocationCharacter")
  timelineEvents        TimelineEvent[] @relation("TimelineEventCharacters")
  documentDeliveries    SessionDocumentDelivery[]
  trombinoscopeViewerEntries CharacterTrombinoscopeEntry[] @relation("TrombinoscopeViewerEntries")
  trombinoscopeTargetEntries CharacterTrombinoscopeEntry[] @relation("TrombinoscopeTargetEntries")
  trombinoscopeDocuments SessionTrombinoscope[] @relation("TrombinoscopeViewerDocuments")
}

model CharacterTrombinoscopeEntry {
  id                String    @id @default(cuid())
  viewerCharacterId String
  targetCharacterId String
  included          Boolean   @default(true)
  faceKnown         Boolean   @default(true)
  displayName       String?
  note              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  viewerCharacter   Character @relation("TrombinoscopeViewerEntries", fields: [viewerCharacterId], references: [id], onDelete: Cascade)
  targetCharacter   Character @relation("TrombinoscopeTargetEntries", fields: [targetCharacterId], references: [id], onDelete: Cascade)

  @@unique([viewerCharacterId, targetCharacterId])
  @@index([targetCharacterId])
}

model Item {
  id                    String       @id @default(cuid())
  name                  String
  description           String?
  quantity              Int          @default(1)
  locationText          String?
  locationCharacterId   String?
  locationCharacter     Character?   @relation("ItemLocationCharacter", fields: [locationCharacterId], references: [id], onDelete: SetNull)
  gameId                String
  game                  Game         @relation(fields: [gameId], references: [id])
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  published             Boolean      @default(true)

  characters            Character[]   @relation("CharacterItems")
  intrigues             Intrigue[]    @relation("IntrigueItems")
  timelineEvents        TimelineEvent[] @relation("TimelineEventItems")
}

model Faction {
  id                    String     @id @default(cuid())
  name                  String
  pitch                 String?
  background            String?
  backgroundDocumentUrl String?
  costumeIndications    String?
  slug                  String     @unique
  gameId                String
  game                  Game       @relation(fields: [gameId], references: [id])
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  published             Boolean    @default(true)

  characters            Character[] @relation("CharacterFactions")
  intrigues             Intrigue[]  @relation("FactionIntrigues")
  timelineEvents        TimelineEvent[] @relation("TimelineEventFactions")
  documents             Document[]  @relation("DocumentFactions")
}

model Intrigue {
  id          String    @id @default(cuid())
  name        String
  pitch       String?
  description String?
  level       String    @default("minor")
  slug        String    @unique
  gameId      String
  game        Game      @relation(fields: [gameId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  published   Boolean   @default(true)

  characters  Character[] @relation("CharacterIntrigues")
  factions    Faction[]   @relation("FactionIntrigues")
  items       Item[]      @relation("IntrigueItems")
  timelineEvents TimelineEvent[] @relation("TimelineEventIntrigues")
}

model TimelineEvent {
  id                    String     @id @default(cuid())
  name                  String
  description           String?
  day                   Int
  time                  String
  requiredResponsibles  Int        @default(0)
  gameId                String
  game                  Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  published             Boolean    @default(true)

  characters            Character[] @relation("TimelineEventCharacters")
  factions              Faction[]   @relation("TimelineEventFactions")
  intrigues             Intrigue[]  @relation("TimelineEventIntrigues")
  items                 Item[]      @relation("TimelineEventItems")
  responsibles          TimelineEventResponsible[]

  @@index([gameId, day, time])
}

model Document {
  id          String      @id @default(cuid())
  title       String
  content     String?
  documentUrl String?
  audience    String      @default("targeted")
  readyToSend Boolean     @default(false)
  gameId      String
  game        Game        @relation(fields: [gameId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  published   Boolean     @default(true)

  characterId String?
  character   Character?  @relation(fields: [characterId], references: [id], onDelete: SetNull)
  characters  Character[]  @relation("DocumentCharacters")

  factions    Faction[]   @relation("DocumentFactions")
  deliveries  SessionDocumentDelivery[]
}

model Session {
  id          String     @id @default(cuid())
  name        String
  date        DateTime?
  gameId      String
  game        Game       @relation(fields: [gameId], references: [id])
  locationId  String?
  location    Location?  @relation(fields: [locationId], references: [id])
  status      String     @default("scheduled")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  published   Boolean    @default(true)

  assignments SessionAssignment[]
  participants SessionParticipant[]
  timelineResponsibles TimelineEventResponsible[]
  documentDeliveries SessionDocumentDelivery[]
  trombinoscopes SessionTrombinoscope[]
}

model SessionAssignment {
  id          String   @id @default(cuid())
  sessionId   String
  characterId String
  participantId String?
  photoUrl    String?
  notes       String?
  session     Session  @relation(fields: [sessionId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  participant Participant? @relation(fields: [participantId], references: [id])

  @@unique([sessionId, characterId])
}

model SessionParticipant {
  id            String      @id @default(cuid())
  sessionId     String
  participantId String
  role          String
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([sessionId, participantId, role])
  @@index([participantId])
}

model Location {
  id          String     @id @default(cuid())
  name        String
  address     String?
  notes       String?
  gameId      String
  game        Game       @relation(fields: [gameId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  published   Boolean    @default(true)

  sessions    Session[]
}

model Participant {
  id          String     @id @default(cuid())
  name        String
  email       String?
  phone       String?
  notes       String?
  gameLinks   ParticipantGame[]
  published   Boolean    @default(true)

  assignments SessionAssignment[]
  sessionRoles SessionParticipant[]
  timelineResponsibilities TimelineEventResponsible[]
  documentDeliveries SessionDocumentDelivery[]
  trombinoscopes SessionTrombinoscope[]
}

model SessionTrombinoscope {
  id                String      @id @default(cuid())
  sessionId         String
  viewerCharacterId String
  participantId     String
  fileName          String
  contentHtml       String
  missingPhotos     Int         @default(0)
  generatedAt       DateTime    @default(now())

  session           Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  viewerCharacter   Character   @relation("TrombinoscopeViewerDocuments", fields: [viewerCharacterId], references: [id], onDelete: Cascade)
  participant       Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([sessionId, viewerCharacterId, participantId])
  @@index([participantId])
}

model SessionDocumentDelivery {
  id            String      @id @default(cuid())
  sessionId     String
  participantId String
  documentId    String?
  characterId   String?
  kind          String      @default("document")
  sentAt        DateTime    @default(now())

  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  document      Document?   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  character     Character?  @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([sessionId, kind])
  @@index([participantId])
  @@index([documentId])
  @@index([characterId])
}

model TimelineEventResponsible {
  id              String        @id @default(cuid())
  sessionId       String
  timelineEventId String
  participantId   String
  session         Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  timelineEvent   TimelineEvent @relation(fields: [timelineEventId], references: [id], onDelete: Cascade)
  participant     Participant   @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([sessionId, timelineEventId, participantId])
  @@index([participantId])
  @@index([timelineEventId])
}

model ParticipantGame {
  id        String   @id @default(cuid())
  participantId String
  gameId    String
  createdAt DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([participantId, gameId])
  @@index([gameId])
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String
  role     String
}
